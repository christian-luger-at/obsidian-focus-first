{
	"name": "focus-first",
	"version": "1.6.9",
	"description": "Automatically sorts your existing tasks into an Eisenhower or Value/Effort matrix by due date, priority, and size. Pin a task when context beats the rule, with one click back to automatic.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json styles.css",
		"lint": "eslint .",
		"test": "vitest run",
		"test:tz": "TZ=America/New_York vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"release": "bash release.sh",
		"release:publish": "bash release.sh --publish",
		"release:patch": "bash release.sh --bump patch --publish",
		"release:minor": "bash release.sh --bump minor --publish",
		"release:major": "bash release.sh --bump major --publish",
		"docs:shots": "node scripts/screenshots.mjs"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"@vitest/coverage-v8": "^4.1.9",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"playwright-core": "^1.61.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitepress": "^1.6.4",
		"vitest": "^4.1.9"
	}
}
